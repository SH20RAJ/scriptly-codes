---
import "../styles/app.css";
import Frame from "../components/frame.astro";
import Nav from "../components/nav.astro";
import TransitionSvgWrapper from "../components/TransitionSvgWrapper.astro";
import TransitionOverlay from "../components/TransitionOverlay.astro";
import TransitionMorphSvg from "../components/TransitionMorphSvg.astro";
const { uid } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <title>VORTEX — Creative Agency & Production Studio</title>
    <link rel="icon" type="image/svg+xml" href="data:image/svg+xml,%3Csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'%3E%3Crect width='100' height='100' fill='%230f0f11'/%3E%3Ctext x='50%25' y='65%25' font-family='Outfit, sans-serif' font-weight='900' font-size='60' fill='%23c2a05d' text-anchor='middle'%3EV%3C/text%3E%3C/svg%3E" />
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700;900&family=Plus+Jakarta+Sans:wght@300;400;500;600;700&display=swap" rel="stylesheet">
  </head>
  <body data-barba="wrapper">
    <Frame />
    <div data-barba="container" data-barba-namespace={uid} class="app__wrapper">
      <main class="content__wrapper">
        <slot />
      </main>
    </div>
    <Nav />
    <TransitionSvgWrapper />
    <TransitionOverlay />
    <TransitionMorphSvg />
    <script src="../scripts/app.js"></script>
  </body>
</html>
