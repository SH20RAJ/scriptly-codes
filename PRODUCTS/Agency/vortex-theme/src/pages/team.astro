---
import Layout from "../layouts/Layout.astro";
---

<Layout uid="team">
  <div class="content team">
    <div class="section-tag" data-motion-text="true" data-motion-text-split="words" data-motion-text-duration="0.8">
      CREATIVE VISIONARIES
    </div>
    
    <h1
      class="title section-title"
      data-motion-text="true"
      data-motion-text-split="chars"
      data-motion-text-duration="0.8"
    >
      CREW
    </h1>
    
    <div class="team-grid">
      <div class="team-member">
        <span class="member-role">FOUNDER & ART DIRECTOR</span>
        <h3>SHASWAT RAJ</h3>
        <p>Directs the design language, aesthetic focus, and brand philosophy across all client collaborations.</p>
      </div>
      <div class="team-member">
        <span class="member-role">CREATIVE DEVELOPER</span>
        <h3>@SH20RAJ</h3>
        <p>Bridges the gap between technical complexity and sensory beauty, writing custom shaders and WebGL structures.</p>
      </div>
      <div class="team-member">
        <span class="member-role">MOTION DESIGN DIRECTOR</span>
        <h3>IQBAL MUTH</h3>
        <p>Orchestrates micro-interactions, layout physics, and screen-space transitions for seamless user experiences.</p>
      </div>
    </div>
  </div>
</Layout>
