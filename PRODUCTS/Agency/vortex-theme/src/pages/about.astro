---
import Layout from "../layouts/Layout.astro";
---

<Layout uid="about">
  <div class="content about">
    <div class="section-tag" data-motion-text="true" data-motion-text-split="words" data-motion-text-duration="0.8">
      STUDIO PROFILE
    </div>
    
    <h1
      class="title section-title"
      data-motion-text="true"
      data-motion-text-split="chars"
      data-motion-text-duration="0.8"
    >
      ABOUT
    </h1>
    
    <div class="about-grid">
      <div class="about-block">
        <h3>WHO WE ARE</h3>
        <p>Vortex is a multidisciplinary design and technology collective working at the intersection of aesthetic precision and engineering excellence. We collaborate with forward-thinking luxury brands to craft unique interactive systems.</p>
      </div>
      <div class="about-block">
        <h3>OUR CAPABILITIES</h3>
        <ul class="capabilities-list">
          <li>● WebGL & Shaders (Three.js, GLSL)</li>
          <li>● Immersive 3D Development & GSAP</li>
          <li>● Creative Art Direction & Typography</li>
          <li>● Performance Optimization & Astro</li>
        </ul>
      </div>
      <div class="about-block">
        <h3>OUR APPROACH</h3>
        <p>We believe digital interfaces should be experienced, not just navigated. Every pixel is intentional, every animation serves a story, and every line of code is optimized for maximum sensory impact.</p>
      </div>
    </div>
  </div>
</Layout>
