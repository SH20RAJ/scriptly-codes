---
import Layout from "../layouts/Layout.astro";
---

<Layout uid="archive">
  <div class="content archive">
    <div class="section-tag" data-motion-text="true" data-motion-text-split="words" data-motion-text-duration="0.8">
      STUDIO RECOGNITION & AWARDS
    </div>
    
    <h1
      class="title section-title"
      data-motion-text="true"
      data-motion-text-split="chars"
      data-motion-text-duration="0.8"
    >
      AWARDS
    </h1>
    
    <div class="archive-list">
      <div class="archive-row">
        <span class="archive-year">2026</span>
        <span class="archive-award">Awwwards Site of the Day</span>
        <span class="archive-project">Aura Editorial Catalog</span>
      </div>
      <div class="archive-row">
        <span class="archive-year">2025</span>
        <span class="archive-award">FWA Site of the Month</span>
        <span class="archive-project">Kraft Charcoal Canvas</span>
      </div>
      <div class="archive-row">
        <span class="archive-year">2025</span>
        <span class="archive-award">CSSDA Best UI/UX Design</span>
        <span class="archive-project">Lumiere Gallery Viewport</span>
      </div>
      <div class="archive-row">
        <span class="archive-year">2024</span>
        <span class="archive-award">Awwwards Honorable Mention</span>
        <span class="archive-project">Matter Spatial Architecture</span>
      </div>
    </div>
  </div>
</Layout>
