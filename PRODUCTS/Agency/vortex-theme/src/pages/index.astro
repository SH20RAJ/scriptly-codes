---
import Layout from "../layouts/Layout.astro";
---

<Layout uid="index">
  <div class="content hero">
    <div class="hero__badge" data-motion-text="true" data-motion-text-split="words" data-motion-text-duration="0.8">
      CREATIVE DEVELOPMENT STUDIO
    </div>
    
    <h1
      class="title hero__title"
      data-motion-text="true"
      data-motion-text-split="chars"
      data-motion-text-duration="0.8"
    >
      VORTEX
    </h1>
    
    <p class="hero__subtitle" data-motion-text="true" data-motion-text-split="words" data-motion-text-duration="0.9" data-motion-text-stagger="0.02">
      Crafting high-performance WebGL interfaces, luxury digital identities, and immersive interactive campaigns that redefine digital luxury.
    </p>

    <div class="hero__cta">
      <a href="/works" class="cta-btn primary">Explore Showcase</a>
      <a href="/contact" class="cta-btn secondary">Start a Project</a>
    </div>
  </div>
</Layout>
