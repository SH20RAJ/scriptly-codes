---
import Layout from "../layouts/Layout.astro";
---

<Layout uid="works">
  <div class="content works">
    <div class="section-tag" data-motion-text="true" data-motion-text-split="words" data-motion-text-duration="0.8">
      SELECTED COMMISSIONS
    </div>
    
    <h1
      class="title section-title"
      data-motion-text="true"
      data-motion-text-split="chars"
      data-motion-text-duration="0.8"
    >
      WORKS
    </h1>
    
    <div class="works-grid">
      <div class="work-card">
        <span class="work-number">01</span>
        <div class="work-content">
          <h3>AURA EDITORIAL</h3>
          <p>Next-gen editorial catalog for a luxury fashion house, featuring fluid typography and custom smooth scrolling mechanics.</p>
        </div>
      </div>
      <div class="work-card">
        <span class="work-number">02</span>
        <div class="work-content">
          <h3>KRAFT DRAWING</h3>
          <p>An interactive, shader-based drafting canvas mimicking charcoal sketching directly in the WebGL viewport.</p>
        </div>
      </div>
      <div class="work-card">
        <span class="work-number">03</span>
        <div class="work-content">
          <h3>LUMIERE ARCHIVE</h3>
          <p>An immersive dark 3D gallery rendering historical fashion artifacts with WebGL displacement maps.</p>
        </div>
      </div>
      <div class="work-card">
        <span class="work-number">04</span>
        <div class="work-content">
          <h3>MATTER SPATIAL</h3>
          <p>Interactive spatial web layout developed for a premium Swiss design studio utilizing WebGL page transitions.</p>
        </div>
      </div>
    </div>
  </div>
</Layout>
